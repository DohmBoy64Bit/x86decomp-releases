{
  "schema_version": 1,
  "id": "lm-studio-qwen-coder",
  "provider": "lm-studio",
  "protocol": "openai-chat",
  "base_url": "http://127.0.0.1:1234/v1",
  "models_path": "/models",
  "chat_path": "/chat/completions",
  "structured_output": "openai-json-schema",
  "model": "replace-with-loaded-model-id",
  "temperature": 0.0,
  "max_tokens": 4096,
  "timeout_seconds": 180,
  "max_response_bytes": 2097152,
  "verify_tls": true,
  "allow_remote": false,
  "api_key_env": null,
  "headers": {}
}
