{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:x86decomp-test-suite:run-report:1",
  "title": "x86decomp comprehensive test run report",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "run_id", "toolkit_root", "output_directory", "strict", "started_at", "finished_at", "adapter_results", "test_results", "inventory", "configuration", "counts", "exit_code"],
  "properties": {
    "schema_version": {"const": 1},
    "run_id": {"type": "string", "minLength": 1},
    "toolkit_root": {"type": "string"},
    "output_directory": {"type": "string"},
    "strict": {"type": "boolean"},
    "adapter_results": {"type": "array"},
    "test_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["test_id", "suite", "status", "summary"],
        "properties": {
          "status": {"enum": ["pass", "fail", "blocked", "error"]}
        }
      }
    },
    "counts": {
      "type": "object",
      "required": ["pass", "fail", "blocked", "error"],
      "properties": {
        "pass": {"type": "integer", "minimum": 0},
        "fail": {"type": "integer", "minimum": 0},
        "blocked": {"type": "integer", "minimum": 0},
        "error": {"type": "integer", "minimum": 0}
      }
    },
    "exit_code": {"enum": [0, 1, 2]}
  }
}
