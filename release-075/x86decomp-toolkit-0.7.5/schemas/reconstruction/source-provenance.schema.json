{
  "$id": "https://x86decomp.dev/schemas/reconstruction/source-provenance.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "address_end": {
      "minLength": 1,
      "type": "string"
    },
    "address_start": {
      "minLength": 1,
      "type": "string"
    },
    "binary_id": {
      "minLength": 1,
      "type": "string"
    },
    "confidence": {
      "maximum": 1,
      "minimum": 0,
      "type": "number"
    },
    "evidence": {
      "items": {
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "line_end": {
      "minimum": 1,
      "type": "integer"
    },
    "line_start": {
      "minimum": 1,
      "type": "integer"
    },
    "provenance_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$",
      "type": "string"
    },
    "source_path": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "provenance_id",
    "source_path",
    "line_start",
    "line_end",
    "binary_id",
    "address_start",
    "address_end",
    "evidence",
    "confidence"
  ],
  "title": "Source provenance record",
  "type": "object"
}
