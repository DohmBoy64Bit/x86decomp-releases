{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:x86decomp-test-suite:test-config:1",
  "title": "x86decomp test configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "toolkit_root", "output_root", "adapter_paths", "python_executable", "strict", "interactive", "allow_network", "allow_install", "allow_host_execution", "timeout_seconds", "line_coverage_floor", "branch_coverage_floor", "require_public_api_execution", "custom_environment"],
  "properties": {
    "schema_version": {"const": 1},
    "toolkit_root": {"type": "string", "minLength": 1},
    "output_root": {"type": "string", "minLength": 1},
    "adapter_paths": {"type": "object", "additionalProperties": {"type": "string", "minLength": 1}},
    "install_root": {"type": ["string", "null"]},
    "python_executable": {"type": "string", "minLength": 1},
    "strict": {"type": "boolean"},
    "interactive": {"type": "boolean"},
    "allow_network": {"type": "boolean"},
    "allow_install": {"type": "boolean"},
    "allow_host_execution": {"type": "boolean"},
    "timeout_seconds": {"type": "integer", "minimum": 1},
    "line_coverage_floor": {"type": "number", "minimum": 0, "maximum": 100},
    "branch_coverage_floor": {"type": "number", "minimum": 0, "maximum": 100},
    "require_public_api_execution": {"type": "boolean"},
    "custom_environment": {"type": "object", "additionalProperties": {"type": "string"}}
  }
}
