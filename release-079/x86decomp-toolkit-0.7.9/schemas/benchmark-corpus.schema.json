{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:x86decomp:schema:benchmark-corpus:1",
  "title": "Ground-truth benchmark corpus",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "name",
    "cases"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "kind"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "kind": {
            "enum": [
              "byte_pair",
              "pe_coff",
              "dynamic",
              "symbolic",
              "integration",
              "discovery_metrics"
            ]
          },
          "human_interventions": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": true
      }
    }
  }
}
