{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "current_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "type": "string"
    },
    "predicate": {
      "type": "object"
    },
    "provenance": {
      "type": "object"
    },
    "scope_id": {
      "type": "string"
    },
    "scope_kind": {
      "type": "string"
    },
    "size_bytes": {
      "minimum": 1,
      "type": "integer"
    },
    "state": {
      "enum": [
        "recorded",
        "minimized",
        "regression"
      ]
    }
  },
  "required": [
    "scope_kind",
    "scope_id",
    "current_sha256",
    "size_bytes",
    "state",
    "predicate"
  ],
  "title": "counterexample",
  "type": "object"
}
