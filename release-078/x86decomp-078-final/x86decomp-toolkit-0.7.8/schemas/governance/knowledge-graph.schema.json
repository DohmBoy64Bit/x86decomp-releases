{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "direction": {
      "enum": [
        "outbound",
        "inbound",
        "both"
      ]
    },
    "edges": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "max_depth": {
      "maximum": 64,
      "minimum": 0,
      "type": "integer"
    },
    "nodes": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "root": {
      "type": "string"
    }
  },
  "required": [
    "root",
    "direction",
    "max_depth",
    "nodes",
    "edges"
  ],
  "title": "knowledge graph impact",
  "type": "object"
}
